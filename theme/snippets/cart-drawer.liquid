{%- comment -%} Slide-out cart drawer, hydrated by global.js via /cart.js {%- endcomment -%}
<aside class="drawer" data-cart-drawer aria-label="Cart" aria-hidden="true">
  <div class="drawer__head">
    <h3>Your cart</h3>
    <button class="icon-btn" data-cart-close aria-label="Close cart">{% render 'icon', name: 'close' %}</button>
  </div>
  <div class="drawer__free" data-freeship-bar>
    <span data-freeship-msg>Free shipping on orders over {{ 5000 | money_without_trailing_zeros }}</span>
    <div class="drawer__bar"><span style="width:0"></span></div>
  </div>
  <div class="drawer__body" data-cart-body>
    <div class="drawer-empty"><p>Your cart is empty.</p><a class="button button--primary" href="{{ routes.all_products_collection_url }}">Shop all</a></div>
  </div>
  <div class="drawer__foot" data-cart-foot style="display:none">
    <div class="drawer__subtotal"><span>Subtotal</span><span data-cart-subtotal>{{ 0 | money }}</span></div>
    <a href="{{ routes.cart_url }}" class="button button--outline button--full" style="margin-bottom:8px">View cart</a>
    <a href="/checkout" class="button button--primary button--full">Checkout</a>
  </div>
</aside>
