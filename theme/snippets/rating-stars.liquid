{%- comment -%}
  Star rating. Reads Judge.me-style product metafields if present, else uses
  a sensible default so the design always looks complete in the editor.
  Usage: {% render 'rating-stars', product: product, show_count: true %}
{%- endcomment -%}
{%- liquid
  assign rating = 4.8
  assign count = 0
  if product and product.metafields.reviews.rating.value != blank
    assign rating = product.metafields.reviews.rating.value.rating | times: 1.0
    assign count = product.metafields.reviews.rating_count.value | default: 0
  endif
  assign full = rating | round
-%}
<span class="rating">
  <span class="stars" aria-hidden="true">
    {%- for i in (1..5) -%}
      {%- if i <= full -%}
        {% render 'icon', name: 'star' %}
      {%- else -%}
        <span class="empty">{% render 'icon', name: 'star' %}</span>
      {%- endif -%}
    {%- endfor -%}
  </span>
  {%- if show_count -%}
    <span>{{ rating }}{% if count > 0 %} ({{ count }}){% endif %}</span>
  {%- endif -%}
</span>
