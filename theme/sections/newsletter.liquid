<section class="section">
  <div class="page-width">
    <div class="newsletter">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      <p class="lede" style="margin:0 auto">{{ section.settings.text }}</p>
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,homepage">
        {%- if form.posted_successfully? -%}
          <p class="form-success" style="max-width:480px;margin:18px auto 0">Thanks! Check your inbox for your 10% code.</p>
        {%- else -%}
          <div style="display:flex;gap:10px;max-width:480px;margin:24px auto 0;flex-wrap:wrap">
            <input type="email" name="contact[email]" placeholder="Your email address" required
                   style="flex:1;min-width:0;padding:15px 18px;border-radius:999px;border:1px solid rgba(43,38,34,.18);font-family:inherit;background:#fff">
            <button type="submit" class="button button--primary">{{ section.settings.button_text }}</button>
          </div>
        {%- endif -%}
      {%- endform -%}
      <p class="field-note">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the glow list" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 10% off your first order" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Sign up for skincare tips, new launches and members-only offers." },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Sign me up" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
