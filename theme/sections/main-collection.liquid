{%- paginate collection.products by 12 -%}
<div class="collection-hero page-width">
  <p class="eyebrow">Collection</p>
  <h1>{{ collection.title }}</h1>
  {%- if collection.description != blank -%}<p class="lede" style="margin:8px auto 0">{{ collection.description | strip_html | truncatewords: 40 }}</p>{%- endif -%}
</div>

<section class="section--tight section">
  <div class="page-width">
    <form method="get" class="collection-toolbar" id="FacetForm">
      <div class="facets">
        {%- for filter in collection.filters -%}
          {%- if filter.type == 'list' -%}
            <select name="{{ filter.param_name }}" onchange="this.form.submit()">
              <option value="">{{ filter.label }}: All</option>
              {%- for value in filter.values -%}
                <option value="{{ value.value }}" {% if value.active %}selected{% endif %}>{{ value.label }} ({{ value.count }})</option>
              {%- endfor -%}
            </select>
          {%- endif -%}
        {%- endfor -%}
        <span class="collection-count">{{ collection.products_count }} products</span>
      </div>
      <select name="sort_by" onchange="this.form.submit()" aria-label="Sort">
        {%- assign sort = collection.sort_by | default: collection.default_sort_by -%}
        <option value="manual" {% if sort == 'manual' %}selected{% endif %}>Featured</option>
        <option value="best-selling" {% if sort == 'best-selling' %}selected{% endif %}>Best selling</option>
        <option value="title-ascending" {% if sort == 'title-ascending' %}selected{% endif %}>Alphabetical, A–Z</option>
        <option value="price-ascending" {% if sort == 'price-ascending' %}selected{% endif %}>Price, low to high</option>
        <option value="price-descending" {% if sort == 'price-descending' %}selected{% endif %}>Price, high to low</option>
        <option value="created-descending" {% if sort == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
    </form>

    {%- if collection.products.size > 0 -%}
      <div class="product-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">←</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}<span class="current">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">→</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- else -%}
      <div class="cart-empty"><h3>No products found</h3><p class="lede" style="margin:0 auto">Try removing a filter or browse all products.</p><a class="button button--primary" style="margin-top:18px" href="{{ routes.all_products_collection_url }}">Shop all</a></div>
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
