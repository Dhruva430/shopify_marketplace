<div class="collection-hero page-width">
  <p class="eyebrow">Catalog</p>
  <h1>{{ section.settings.heading | default: 'Shop collections' }}</h1>
</div>
<section class="section--tight section">
  <div class="page-width">
    <div class="collection-grid">
      {%- for collection in collections -%}
        <a class="coll-card" href="{{ collection.url }}">
          {%- if collection.featured_image -%}
            <img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title }}" width="800" height="1000" loading="lazy">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
          {%- endif -%}
          <div class="coll-card__body"><h3>{{ collection.title }}</h3><span>{{ collection.products_count }} products</span></div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collections list", "settings": [ { "type": "text", "id": "heading", "label": "Heading", "default": "Shop collections" } ] }
{% endschema %}
