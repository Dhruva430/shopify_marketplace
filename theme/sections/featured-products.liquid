<section class="section">
  <div class="page-width">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    </div>

    {%- assign coll = section.settings.collection -%}
    <div class="product-grid">
      {%- if coll != blank and coll.products_count > 0 -%}
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.limit) -%}
          {% render 'product-card', product: blank %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="text-center" style="margin-top:40px">
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="button button--outline">{{ section.settings.button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Best sellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by skin like yours" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our most-reviewed formulas, chosen again and again." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 2, "max": 8, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "text", "id": "button_text", "label": "Button label", "default": "Shop all products" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
