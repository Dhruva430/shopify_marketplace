<div class="collection-hero page-width">
  <p class="eyebrow">Search</p>
  <h1>Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:520px;margin:18px auto 0;display:flex;gap:8px">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products…" required
           style="flex:1;min-width:0;padding:14px 18px;border-radius:999px;border:1px solid rgba(43,38,34,.18);background:#fff;font-family:inherit">
    <button type="submit" class="button button--primary">Search</button>
  </form>
</div>

<section class="section--tight section">
  <div class="page-width">
    {%- if search.performed -%}
      <p class="collection-count" style="text-align:center;margin-bottom:24px">{{ search.results_count }} results for “{{ search.terms }}”</p>
      {%- if search.results.size > 0 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a class="card" href="{{ item.url }}"><div class="card__body"><div class="card__title">{{ item.title }}</div><p style="color:var(--color-muted);font-size:.88rem">{{ item.content | strip_html | truncatewords: 20 }}</p></div></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="cart-empty"><h3>No results</h3><p class="lede" style="margin:0 auto">Try a different search term.</p></div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
