<section class="section section--sage">
  <div class="page-width">
    <div class="section-head">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="benefits">
      {%- for block in section.blocks -%}
        <div class="benefit" {{ block.shopify_attributes }}>
          <div class="benefit__icon">{% render 'icon', name: block.settings.icon %}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits / USP",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Aurelle" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Skincare you can trust" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "leaf", "label": "Leaf" },
          { "value": "flask", "label": "Flask" },
          { "value": "rabbit", "label": "Cruelty-free" },
          { "value": "drop", "label": "Drop" },
          { "value": "shield", "label": "Shield" },
          { "value": "sprout", "label": "Sprout" }
        ], "default": "leaf" },
        { "type": "text", "id": "title", "label": "Title", "default": "Clean ingredients" },
        { "type": "text", "id": "text", "label": "Text", "default": "No parabens, sulfates, or synthetic fragrance — ever." }
      ]
    }
  ],
  "presets": [{
    "name": "Benefits / USP",
    "blocks": [
      { "type": "benefit", "settings": { "icon": "flask", "title": "Proven actives", "text": "Clinically-backed ingredients at effective concentrations." } },
      { "type": "benefit", "settings": { "icon": "rabbit", "title": "Cruelty-free", "text": "Never tested on animals. Leaping Bunny certified." } },
      { "type": "benefit", "settings": { "icon": "leaf", "title": "Clean formulas", "text": "Free from parabens, sulfates & synthetic fragrance." } },
      { "type": "benefit", "settings": { "icon": "shield", "title": "Dermatologist tested", "text": "Gentle on sensitive skin, suitable for daily use." } }
    ]
  }]
}
{% endschema %}
