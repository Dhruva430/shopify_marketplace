<div class="page-hero">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading | default: page.title | default: 'FAQ' }}</h1>
  </div>
</div>
<section class="section">
  <div class="page-width" style="max-width:780px">
    <div class="accordion">
      {%- for block in section.blocks -%}
        <details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="accordion__body rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
    {%- if page.content != blank -%}<div class="rte" style="margin-top:32px">{{ page.content }}</div>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Help center" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" }
  ],
  "blocks": [
    { "type": "qa", "name": "Question", "settings": [
      { "type": "text", "id": "question", "label": "Question", "default": "How long until I see results?" },
      { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Most customers notice smoother, more hydrated skin within 1–2 weeks, with fuller results around the 4-week mark.</p>" }
    ]}
  ],
  "presets": [{
    "name": "FAQ",
    "blocks": [
      { "type": "qa", "settings": { "question": "How long until I see results?", "answer": "<p>Most customers see visible results within 2–4 weeks of consistent use, morning and night.</p>" } },
      { "type": "qa", "settings": { "question": "Are your products suitable for sensitive skin?", "answer": "<p>Yes — our formulas are fragrance-free and dermatologist tested. We always recommend a patch test first.</p>" } },
      { "type": "qa", "settings": { "question": "What is your shipping policy?", "answer": "<p>Free standard shipping on orders over $50. Orders ship within 1–2 business days.</p>" } },
      { "type": "qa", "settings": { "question": "What is your return policy?", "answer": "<p>If you’re not happy, return within 30 days for a full refund — even if the bottle is open.</p>" } },
      { "type": "qa", "settings": { "question": "Can I subscribe and save?", "answer": "<p>Yes. Choose “Subscribe & save” on any eligible product to save and get free shipping on every refill.</p>" } }
    ]
  }]
}
{% endschema %}
