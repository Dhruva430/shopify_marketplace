<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ shop.name }}</title>
    {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
    {{ content_for_header }}
    {%- style -%}
      :root{
        --color-bg: {{ settings.color_background }};
        --color-text: {{ settings.color_text }};
        --color-secondary: {{ settings.color_secondary }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-text: {{ settings.color_accent_text }};
        --font-heading:"Fraunces",Georgia,serif;
        --font-body:"Jost",Arial,sans-serif;
      }
      *{box-sizing:border-box}
      body{margin:0;font-family:var(--font-body);color:var(--color-text);
        background:linear-gradient(160deg,#F6F1EA 0%,#DCE3D6 100%);
        min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px}
      .pw{max-width:460px;width:100%;text-align:center}
      .pw__brand{font-family:var(--font-heading);font-size:42px;letter-spacing:2px;margin:0 0 6px}
      .pw__tag{color:#8C857C;letter-spacing:3px;text-transform:uppercase;font-size:12px;margin-bottom:36px}
      .pw__card{background:#FFFDF9;border:1px solid rgba(43,38,34,.08);border-radius:18px;padding:40px 32px;
        box-shadow:0 30px 60px -30px rgba(43,38,34,.35)}
      .pw__card h2{font-family:var(--font-heading);font-weight:600;font-size:24px;margin:0 0 8px}
      .pw__card p{color:#8C857C;margin:0 0 24px;font-size:15px;line-height:1.6}
      .pw__form{display:flex;gap:8px;flex-wrap:wrap}
      .pw__form input[type=password]{flex:1;min-width:0;padding:14px 16px;border:1px solid rgba(43,38,34,.18);
        border-radius:10px;font-family:inherit;font-size:15px;background:#fff}
      .pw__form button{background:var(--color-accent);color:var(--color-accent-text);border:0;border-radius:10px;
        padding:14px 22px;font-family:inherit;font-weight:600;cursor:pointer;letter-spacing:.5px}
      .pw__form button:hover{background:#A1573B}
      .pw__err{color:#B23B3B;font-size:14px;margin-top:12px}
      .pw__foot{margin-top:28px;font-size:13px;color:#8C857C}
      .pw__foot a{color:#8C857C}
    {%- endstyle -%}
  </head>
  <body>
    <div class="pw">
      <div class="pw__brand">{{ shop.name }}</div>
      <div class="pw__tag">Clean science. Visible skin.</div>
      <div class="pw__card">
        <h2>We're almost ready</h2>
        <p>Our store is launching soon. Enter the password to take a look inside.</p>
        {%- form 'storefront_password' -%}
          <div class="pw__form">
            <input type="password" name="password" id="password" placeholder="Enter password" autocomplete="off">
            <button type="submit">Enter</button>
          </div>
          {%- if form.errors -%}
            <p class="pw__err">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
      <div class="pw__foot">
        {%- form 'customer', class: 'pw__news' -%}
          {%- if form.posted_successfully? -%}
            <p>Thanks — we'll be in touch.</p>
          {%- endif -%}
        {%- endform -%}
        Are you the store owner? <a href="/admin">Log in here</a>
      </div>
    </div>
    {{ content_for_layout }}
  </body>
</html>
