<section class="section"><div class="page-width" style="max-width:440px">
  <div class="text-center" style="margin-bottom:24px"><p class="eyebrow">Account</p><h1>Reset password</h1></div>
  {%- form 'reset_customer_password', class: 'contact-form' -%}
    {{ form.errors | default_errors }}
    <div><label>New password</label><input type="password" name="customer[password]" required></div>
    <div><label>Confirm password</label><input type="password" name="customer[password_confirmation]" required></div>
    <button type="submit" class="button button--primary">Reset password</button>
  {%- endform -%}
</div></section>
