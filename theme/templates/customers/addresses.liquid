<section class="section"><div class="page-width" style="max-width:640px">
  <p class="eyebrow">My account</p>
  <h1>Addresses</h1>

  {%- form 'customer_address', customer.new_address, class: 'contact-form', style: 'margin:24px 0;padding:24px;background:var(--color-secondary-bg);border-radius:16px' -%}
    <h3 style="margin-top:0">Add a new address</h3>
    <div><label>First name</label><input type="text" name="address[first_name]"></div>
    <div><label>Last name</label><input type="text" name="address[last_name]"></div>
    <div><label>Address</label><input type="text" name="address[address1]"></div>
    <div><label>City</label><input type="text" name="address[city]"></div>
    <div><label>Country</label><input type="text" name="address[country]"></div>
    <div><label>ZIP / Postal</label><input type="text" name="address[zip]"></div>
    <button type="submit" class="button button--primary">Save address</button>
  {%- endform -%}

  {%- for address in customer.addresses -%}
    <div style="padding:18px;border:1px solid rgba(43,38,34,.12);border-radius:14px;margin-bottom:12px">
      <p style="margin:0">{{ address | format_address }}</p>
    </div>
  {%- endfor -%}

  <p><a href="{{ routes.account_url }}" style="text-decoration:underline">← Back to account</a></p>
</div></section>
