<section class="section"><div class="page-width" style="max-width:440px">
  <div class="text-center" style="margin-bottom:24px"><p class="eyebrow">Account</p><h1>Activate account</h1></div>
  {%- form 'activate_customer_password', class: 'contact-form' -%}
    {{ form.errors | default_errors }}
    <div><label>Password</label><input type="password" name="customer[password]" required></div>
    <div><label>Confirm password</label><input type="password" name="customer[password_confirmation]" required></div>
    <button type="submit" class="button button--primary">Activate account</button>
    <button type="submit" name="decline" class="button button--outline">Decline invitation</button>
  {%- endform -%}
</div></section>
