{
  "name": "aurelle-shopify-store",
  "version": "1.0.0",
  "private": true,
  "description": "Aurelle — premium skincare Shopify theme (Liquid) for the Digital Heroes challenge",
  "type": "module",
  "scripts": {
    "dev": "shopify theme dev --path theme --store fetchwell-edyplil9.myshopify.com",
    "push": "shopify theme push --path theme --store fetchwell-edyplil9.myshopify.com",
    "pull": "shopify theme pull --path theme --store fetchwell-edyplil9.myshopify.com",
    "login": "shopify login --store fetchwell-edyplil9.myshopify.com",
    "check": "shopify theme check --path theme",
    "package": "shopify theme package --path theme",
    "gen:images": "node scripts/gen-images.mjs",
    "seed": "node scripts/seed-store.mjs",
    "images:real": "node scripts/set-real-images.mjs"
  },
  "devDependencies": {
    "@shopify/cli": "^3.66.0",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
